#!/usr/bin/env bash
# ww-open — workspace-aware URL/file opener
# Opens files/URLs on the current workspace. After the browser handles the
# request, the activated window is brought back to the workspace where the
# user was when they triggered the open.

if [[ -z "$1" ]]; then
    echo "Usage: ww-open <file-or-url>" >&2
    exit 1
fi

# Load config (same lookup logic as window-watcher.sh)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${WINDOW_WATCHER_CONFIG:-$SCRIPT_DIR/config.sh}"
BROWSER_CMD=""

if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
fi

# Auto-detect browser command if not configured
if [[ -z "$BROWSER_CMD" ]]; then
    local_desktop=$(xdg-settings get default-web-browser 2>/dev/null | sed 's/\.desktop$//')
    case "$local_desktop" in
        *firefox*)       BROWSER_CMD="firefox" ;;
        *chromium*)      BROWSER_CMD="chromium" ;;
        *chrome*|*google-chrome*) BROWSER_CMD="google-chrome" ;;
        *)               BROWSER_CMD="" ;;
    esac
fi

# Remember where we are RIGHT NOW
origin_ws=$(wmctrl -d | awk '/\*/ {print $1}')

# Let the browser handle the request normally
"$BROWSER_CMD" "$1" &>/dev/null &

# Wait for the browser to activate/create a window, then bring it here
(
    sleep 0.8
    active_wid=$(xprop -root _NET_ACTIVE_WINDOW 2>/dev/null | grep -oP '0x[0-9a-f]+' | tail -1)
    [[ -z "$active_wid" ]] && exit

    active_wid=$(printf "0x%08x" "$active_wid" 2>/dev/null)
    win_ws=$(wmctrl -lp | awk -v w="$active_wid" '$1 == w {print $2; exit}')

    if [[ "$win_ws" != "$origin_ws" ]]; then
        wmctrl -ir "$active_wid" -t "$origin_ws"
        wmctrl -ia "$active_wid"
    fi
) &
